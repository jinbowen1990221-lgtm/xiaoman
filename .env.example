# ============================================================
# 小满 · 环境变量（复制为 .env.local 后填写真实值）
# ============================================================

# --- 安全 / 会话签名（必填，生产务必改成长随机串）---
# 用于 HMAC 签名登录态；不设会用 dev 默认值（不安全）
SESSION_SECRET=

# --- 验证码（开发用）---
# 本地/测试用的固定验证码；生产改为真实短信，下面 SMS 配好后删掉它
DEV_OTP=123456

# --- 真实短信服务（生产必填，二选一示例：阿里云）---
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# --- Supabase 数据库（生产必填）---
# 在 Supabase 控制台 → Project Settings → API 获取
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI 大模型（可选；不填走本地启发式兜底）---
# 兼容任意 OpenAI 协议端点：通义/豆包/Kimi/OpenAI…
AI_API_KEY=
# 例：https://dashscope.aliyuncs.com/compatible-mode/v1（通义）
AI_BASE_URL=
# 例：qwen-plus / doubao-... / gpt-4o-mini
AI_MODEL=
